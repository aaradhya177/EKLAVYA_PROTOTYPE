APP_ENV=test
APP_VERSION=1.0.0-test
DEBUG=true
SECRET_KEY=test-secret-key
DATABASE_URL=sqlite+aiosqlite:///./test_dbs/athleteos-test.db
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=0
DB_POOL_TIMEOUT=30
REDIS_URL=memory://
CELERY_BROKER_URL=memory://
CELERY_RESULT_BACKEND=cache+memory://
CELERY_TASK_ALWAYS_EAGER=true
JWT_SECRET_KEY=test-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=1
S3_ENDPOINT_URL=
S3_BUCKET_NAME=athleteos-test
S3_ACCESS_KEY=
S3_SECRET_KEY=
AWS_REGION=us-east-1
FILE_STORAGE_PATH=./test_dbs/files
SENDGRID_API_KEY=
FROM_EMAIL=noreply@athleteos.in
FIREBASE_CREDENTIALS_PATH=
MODELS_DIR=./models
ML_MIN_AUC_THRESHOLD=0.65
SENTRY_DSN=
SLACK_WEBHOOK_URL=
RATE_LIMIT_PER_MINUTE=100
CORS_ORIGINS=http://localhost:3000
INJURY_KEYWORDS_CONFIG=app/files/config/injury_keywords.yaml
